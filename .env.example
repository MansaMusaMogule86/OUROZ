# OUROZ Frontend Environment Variables

# Base API URL used by the frontend app (optional in local dev)
VITE_API_URL=http://localhost:3001/api

# ─────────────────────────────────────────────
# Supabase (required for Shop section)
# Get these from your Supabase project → Settings → API
# ─────────────────────────────────────────────

# Public anon key – safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key – NEVER expose to browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
