# OUROZ Backend Environment Variables

# Runtime
NODE_ENV=development
PORT=3001

# AI
GEMINI_API_KEY=your_api_key_here

# Auth
JWT_SECRET=replace_with_a_strong_secret

# Database (preferred)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ouroz

# Database (fallback if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ouroz
